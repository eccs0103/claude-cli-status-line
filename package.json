{
	"name": "@eccs0103/claude-cli-status-line",
	"version": "1.2.0",
	"description": "Claude CLI status line command that renders workspace, git branch, model, rate limits and context window as an ANSI-colored line",
	"type": "module",
	"private": false,
	"bin": {
		"claude-cli-status-line": "dist/index.js"
	},
	"files": [ "dist/" ],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/eccs0103/claude-cli-status-line.git"
	},
	"keywords": [ "claude", "cli", "status-line", "ansi" ],
	"author": "eccs0103",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/eccs0103/claude-cli-status-line/issues"
	},
	"homepage": "https://github.com/eccs0103/claude-cli-status-line#readme",
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"test": "npm run build && node dist/index.js --dev < ./resources/data/status-response.json",
		"configure": "npm run build && node dist/index.js --dev config",
		"prepublishOnly": "npm run build"
	},
	"dependencies": {
		"@clack/prompts": "^1.6.0",
		"adaptive-extender": "^0.12.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"typescript": "^6.0.3"
	}
}
